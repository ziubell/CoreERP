{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=CoreERP;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true",
    "Redis": ""
  },
  "Jwt": {
    "Issuer": "CoreERP",
    "Audience": "CoreERP.Web",
    "Key": "CHANGE-THIS-TO-A-SECURE-KEY-IN-PRODUCTION-AT-LEAST-32-CHARS!",
    "ExpirationInMinutes": 120
  },
  "AzureAd": {
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_CLIENT_ID",
    "ClientSecret": "YOUR_CLIENT_SECRET"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*"
}
